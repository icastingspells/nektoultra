{
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "skip-conversation": {
         "description": "Скип собеседника",
         "suggested_key": {
            "default": "Alt+L"
         }
      },
      "toggle-mic": {
         "description": "Вкл/Выкл микрофон",
         "suggested_key": {
            "default": "Alt+M"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "inject-bootstrap.js" ],
      "matches": [ "https://nekto.me/audiochat*", "https://www.nekto.me/audiochat*" ],
      "run_at": "document_start"
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "uwupad_referer",
         "path": "dnr-uwupad.json"
      } ]
   },
   "description": "Авто-скип, изменение голоса, статистика, SoundPad.",
   "host_permissions": [ "https://nekto.me/*", "https://*.nekto.me/*", "https://uwupad.me/*", "https://www.uwupad.me/*", "https://cdn.uwupad.me/*", "https://*.onrender.com/*" ],
   "icons": {
      "128": "icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "NektoPRO — nekto.me",
   "permissions": [ "declarativeNetRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.1",
   "web_accessible_resources": [ {
      "matches": [ "https://nekto.me/*", "https://www.nekto.me/*" ],
      "resources": [ "nekto-pro-inject.js", "vosk-lib.js", "vosk-model-ru.tar.gz" ]
   } ]
}
